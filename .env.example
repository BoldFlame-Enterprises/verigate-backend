# Database Configuration
# Hosted deployments should set DATABASE_URL to the provider's secret URI.
# Local development may leave it empty and use the individual DB_* values.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accreditation_system
DB_USER=postgres
DB_PASSWORD=your_password
DB_POOL_MAX=5
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
# Empty means enabled for DATABASE_URL and disabled for local discrete settings.
DB_SSL=
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional base64-encoded provider CA certificate for verified TLS.
DB_SSL_CA_BASE64=
# Required only while intentionally replacing hosted data with the demo seed.
ALLOW_DATABASE_SEED=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRE_TIME=1h
JWT_REFRESH_EXPIRE_TIME=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Configuration
ENCRYPTION_KEY=your_32_character_encryption_key_here
PEPPER_SECRET=your_pepper_secret_for_passwords

# QR authority signing key. Required outside tests. Supply a base64-encoded
# PKCS#8 DER P-256 private key through the deployment secret manager; never
# commit the private key or distribute it to either mobile application.
QR_AUTHORITY_PRIVATE_KEY_BASE64=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Push notifications - Android FCM (free). Create a Firebase project, enable
# Cloud Messaging, and generate a service account key to fill these in.
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Push notifications - iOS APNs (gated, default OFF). Requires an Apple
# Developer Program membership ($99/yr) + an APNs auth key (.p8). Leave
# APNS_ENABLED=false to run the whole system without any Apple account.
APNS_ENABLED=false
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRODUCTION=false
